\begin_layout Verbatim
for (td::UINT4 node = 1; node <= model.nodeCount; ++node)
\end_layout

\begin_layout Verbatim
  for (td::UINT4 phase = 0; phase < kNumPhases; ++phase) {
\end_layout

\begin_layout Verbatim
    double Vm    = bus(node, 2 + phase*2);
\end_layout

\begin_layout Verbatim
    double VaDeg = bus(node, 3 + phase*2);
\end_layout

\begin_layout Verbatim
    double VaRad = VaDeg * kPi / 180.0;
\end_layout

\begin_layout Verbatim
    outVr(node, phase+1) = Vm * std::cos(VaRad);   // e = Vm*cos
\end_layout

\begin_layout Verbatim
    outVi(node, phase+1) = Vm * std::sin(VaRad);   // f = Vm*sin
\end_layout

\begin_layout Verbatim
    processedSteps.fetch_add(1);                    // za prikaz napretka
\end_layout

\begin_layout Verbatim
  }
\end_layout

