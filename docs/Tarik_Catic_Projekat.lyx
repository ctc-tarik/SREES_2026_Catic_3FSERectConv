    const char* p = row.c_str();
\end_layout

\begin_layout Verbatim
    double values[kMaxSrcCols];
\end_layout

\begin_layout Verbatim
    td::UINT4 count = 0;
\end_layout

\begin_layout Verbatim
    for (;;) {
\end_layout

\begin_layout Verbatim
        while (*p==' '||*p==','||*p=='
\backslash
t'||*p=='
\backslash
r'||*p=='
\backslash
n') ++p;
\end_layout

\begin_layout Verbatim
        if (*p == 0) break;
\end_layout

\begin_layout Verbatim
        char* pEnd = nullptr;
\end_layout

\begin_layout Verbatim
        double v = std::strtod(p, &pEnd);
\end_layout

\begin_layout Verbatim
        if (pEnd == p) break;         // nije broj -> kraj reda
\end_layout

\begin_layout Verbatim
        if (count < nExpectedCols) values[count] = v;
\end_layout

\begin_layout Verbatim
        ++count; p = pEnd;
\end_layout

\begin_layout Verbatim
    }
\end_layout

\begin_layout Verbatim
    if (count == 0) return true;      // prazan red
\end_layout

\begin_layout Verbatim
    if (count != nExpectedCols) { status = "ERROR!..."; return false; }
\end_layout

\begin_layout Verbatim
    for (td::UINT4 i=0; i<nExpectedCols; ++i) flatValues.push_back(values[i]);
\end_layout

\begin_layout Verbatim
    return true;
\end_layout

\begin_layout Verbatim
}
\end_layout

